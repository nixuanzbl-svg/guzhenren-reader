page {
  min-height: 100%;
  background: #f4f2ed;
  color: #222222;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 8px;
  line-height: 1;
  background: transparent;
  color: inherit;
  font: inherit;
}

button::after {
  border: 0;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
