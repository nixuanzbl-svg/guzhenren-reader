.library-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 64rpx 32rpx 42rpx;
  background: #f4f2ed;
}

.topbar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 34rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 8px;
  background: #1f2020;
  color: #f8f4eb;
  font-size: 34rpx;
  font-weight: 700;
}

.brand-copy {
  display: flex;
  flex-direction: column;
}

.brand-title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
}

.brand-subtitle {
  margin-top: 6rpx;
  color: #77746c;
  font-size: 22rpx;
}

.hero {
  display: flex;
  justify-content: space-between;
  min-height: 260rpx;
  padding: 34rpx;
  border-radius: 8px;
  background: linear-gradient(135deg, #282928 0%, #55605a 54%, #9d7650 100%);
  color: #f7f2e9;
  box-shadow: 0 24rpx 60rpx rgba(39, 39, 37, 0.16);
}

.hero-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: space-between;
}

.hero-kicker {
  color: rgba(247, 242, 233, 0.7);
  font-size: 22rpx;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.08;
}

.hero-subtitle {
  max-width: 430rpx;
  margin-top: 24rpx;
  color: rgba(247, 242, 233, 0.82);
  font-size: 25rpx;
  line-height: 1.55;
}

.hero-stat {
  display: flex;
  align-items: flex-end;
  align-self: flex-end;
  gap: 6rpx;
  padding-left: 28rpx;
}

.stat-number {
  font-size: 62rpx;
  font-weight: 800;
  line-height: 1;
}

.stat-label {
  padding-bottom: 8rpx;
  color: rgba(247, 242, 233, 0.7);
  font-size: 24rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 172rpx;
  gap: 20rpx;
  margin: 30rpx 0;
}

.primary-action,
.secondary-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 8px;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-action {
  gap: 16rpx;
  background: #202120;
  color: #f9f4eb;
}

.secondary-action {
  background: #e8e5df;
  color: #55524b;
}

.action-icon {
  font-size: 40rpx;
  line-height: 1;
}

.continue-panel {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(41, 40, 37, 0.08);
  border-radius: 8px;
  background: #fffdf8;
}

.continue-cover,
.book-cover {
  display: flex;
  flex-shrink: 0;
  align-items: flex-end;
  justify-content: center;
  box-sizing: border-box;
  color: #f8f4ec;
  font-weight: 800;
}

.continue-cover {
  width: 132rpx;
  height: 176rpx;
  padding: 16rpx 10rpx;
  border-radius: 8px;
  font-size: 26rpx;
}

.continue-main {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  justify-content: center;
}

.panel-label {
  color: #8c7b60;
  font-size: 22rpx;
  font-weight: 700;
}

.continue-title,
.book-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.continue-title {
  margin-top: 10rpx;
  color: #222222;
  font-size: 34rpx;
  font-weight: 800;
}

.continue-meta {
  margin-top: 10rpx;
  color: #807c73;
  font-size: 24rpx;
}

.progress-track {
  overflow: hidden;
  height: 8rpx;
  margin-top: 22rpx;
  border-radius: 8px;
  background: #ece7dc;
}

.progress-value {
  height: 100%;
  border-radius: 8px;
  background: #1f2020;
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 38rpx 0 18rpx;
  color: #222222;
  font-size: 32rpx;
  font-weight: 800;
}

.section-meta {
  color: #8b877e;
  font-size: 22rpx;
  font-weight: 500;
}

.book-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.book-card {
  display: flex;
  gap: 22rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(41, 40, 37, 0.08);
  border-radius: 8px;
  background: #fffdf8;
}

.book-cover {
  width: 104rpx;
  height: 140rpx;
  padding: 14rpx 8rpx;
  border-radius: 8px;
  font-size: 23rpx;
}

.book-info {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  justify-content: center;
}

.book-title {
  color: #242424;
  font-size: 30rpx;
  font-weight: 800;
}

.book-meta {
  margin-top: 12rpx;
  color: #827e76;
  font-size: 23rpx;
}

.book-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  color: #8c7b60;
  font-size: 23rpx;
  font-weight: 700;
}

.pdf-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 50rpx;
  border-radius: 8px;
  background: #ece8df;
  color: #222222;
  font-size: 22rpx;
  font-weight: 800;
}

.empty-state {
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: center;
  min-height: 430rpx;
  border: 1rpx dashed rgba(36, 36, 33, 0.18);
  border-radius: 8px;
  background: rgba(255, 253, 248, 0.58);
  color: #77736a;
  text-align: center;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  border-radius: 8px;
  background: #e9e5dc;
  color: #56534d;
  font-size: 28rpx;
  font-weight: 800;
}

.empty-title {
  margin-top: 24rpx;
  color: #272727;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-subtitle {
  max-width: 440rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
}
